---
import "@/styles/global.css"

import { pwaInfo } from "virtual:pwa-info"

import { ReminderManager } from "@/components/ReminderManager"
import { ThemeToggle } from "@/components/ThemeToggle"
import { dayRangeLabel, getSessionsLite } from "@/lib/sessions"

interface Props {
  title?: string
}

const { title = "FUN26 – Freelance Unlocked" } = Astro.props
const sessions = await getSessionsLite()
const dayLabel = dayRangeLabel(sessions)
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#E9664C" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <title>{title}</title>
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <script is:inline>
      ;(() => {
        try {
          const stored = localStorage.getItem("fun26.theme")
          const dark = stored
            ? stored === "dark"
            : matchMedia("(prefers-color-scheme: dark)").matches
          document.documentElement.classList.toggle("dark", dark)
        } catch {
          /* default to light */
        }
      })()
    </script>
    <script>
      import { registerSW } from "virtual:pwa-register"
      registerSW({
        immediate: true,
        onRegisteredSW(_url, registration) {
          if (!registration) return
          // Installed PWAs (iOS especially) have no reload button: recheck
          // for a new build whenever the app returns to the foreground and
          // every 15 minutes. autoUpdate then swaps and reloads in place —
          // favorites and settings live in localStorage and are unaffected.
          const check = () => registration.update().catch(() => {})
          document.addEventListener("visibilitychange", () => {
            if (document.visibilityState === "visible") check()
          })
          setInterval(check, 15 * 60_000)
        },
      })
    </script>
  </head>
  <body>
    <div>
      <header class="border-b">
        <div
          class="mx-auto flex h-14 w-full max-w-7xl items-center gap-3 px-3 sm:px-4"
        >
          <a href="/" class="flex items-baseline gap-2 no-underline">
            <span class="text-lg font-black tracking-tight text-primary"
              >FUN26</span
            >
            <span
              class="hidden text-sm font-medium text-muted-foreground sm:inline"
              >Freelance Unlocked</span
            >
          </a>
          <span
            class="rounded-sm bg-muted px-1.5 py-0.5 text-[0.65rem] font-medium tracking-wide text-muted-foreground uppercase"
            title="Community-built app, not affiliated with the organizers"
          >
            unofficial
          </span>
          <nav class="ml-auto flex items-center gap-4">
            <a
              href="/speakers"
              class="text-sm font-medium text-muted-foreground no-underline hover:text-foreground"
            >
              Speakers
            </a>
            <a
              href="/notes"
              class="text-sm font-medium text-muted-foreground no-underline hover:text-foreground"
            >
              Notes
            </a>
          </nav>
          <span
            class="hidden rounded-full border px-2.5 py-0.5 text-xs font-medium text-muted-foreground sm:inline"
          >
            {dayLabel}
          </span>
          <ThemeToggle client:load />
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="border-t">
        <div
          class="mx-auto flex w-full max-w-7xl items-center justify-center px-4 py-5 text-xs text-muted-foreground"
        >
          <span>
            Built by
            <a
              href="https://www.linkedin.com/in/grzegorz-leoniec"
              target="_blank"
              rel="noopener"
              class="font-medium text-foreground underline-offset-2 hover:text-primary hover:underline"
            >
              Grzegorz Leoniec
            </a>
            · unofficial companion app for FUN26
          </span>
        </div>
      </footer>
    </div>
    <ReminderManager client:load sessions={sessions} />
  </body>
</html>
