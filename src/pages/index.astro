---
import Layout from "@/layouts/main.astro"
import { ScheduleApp } from "@/components/schedule/ScheduleApp"
import { getSessionsLite } from "@/lib/sessions"

const sessions = await getSessionsLite()
---

<Layout title="Schedule – FUN26">
  <div class="mx-auto w-full max-w-7xl px-3 sm:px-4">
    <ScheduleApp client:load sessions={sessions} />
  </div>
</Layout>
