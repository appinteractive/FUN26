---
import Layout from "@/layouts/main.astro"
import { ScheduleApp } from "@/components/schedule/ScheduleApp"
import { getSessionsLite, stagesOf } from "@/lib/sessions"

const sessions = await getSessionsLite()
const stages = stagesOf(sessions)
---

<Layout title="Schedule – FUN26" fullHeight>
  <div class="mx-auto h-full w-full max-w-7xl px-4 py-3">
    <ScheduleApp client:load sessions={sessions} stages={stages} />
  </div>
</Layout>
